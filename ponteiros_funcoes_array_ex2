/*2 . Escreva um programa que leia um inteiro n e depois leia n números inteiros para preencher um
vetor. Crie uma função que percorra o vetor e conte quantos elementos são:
● positivos
● negativos
● iguais a zero

Os resultados devem ser retornados por meio de ponteiros.
Ex: void classificar(int *vet, int n, int *positivos, int *negativos, int *zeros);*/
#include <stdio.h>
void classificar(int *vet,int n,int *positivos,int *negativos,int*zeros);
int main() {
//entra na main
int n;
printf("qual o tamanho do nosso vetor ? ");
scanf("%d",&n);
int vet[n];
int positivos = 0,negativos = 0 , zeros = 0 ;
//entra no loop
for(int i=0;i<n;i++){
    int e = i + 1 ;
    printf("digite o [%d] elemento do vetor :",e);
    scanf("%d",&vet[i]);
}
//sai do loop
classificar (vet,n,&positivos,&negativos,&zeros);
printf("positivos %d",positivos);
printf("negativos %d",negativos);
printf("zeros %d",zeros);
//sai da main
}
void classificar(int *vet,int n,int *positivos,int *negativos,int*zeros){
    //começo da função 
    for (int i=0;i<n;i++){
        if (vet[i]>0){
            *positivos += 1 ;
        }else if (vet[i]<0){
            *negativos += 1 ;
        }else {
            *zeros += 1 ;
        }
    }
    //fim da função 
}
