/******************************************************************************
implemente uma função que receba um vetor de N elementos e retorne a quantidade de elementos desse vetor que são maiores que a média 
desses elementos 
*******************************************************************************/
#include <stdio.h>
int valoresmaioresq(int N,int v[N]);
int main()
{
int i = 0 ;
//inicio da main 
int N ; 
printf("digite o tamanho do vetor ");
scanf("%d",&N);
int v[N];
for (i=0;i<N;i++){
    printf("digite o %d valor do vetor\n",i);
    scanf("%d",&v[i]);
}
int maioresqmedia = valoresmaioresq(N,v);
printf("%d",maioresqmedia);
//fim da main  
}

int valoresmaioresq(int N,int v[N]){
int i = 0 ;
int soma = 0 ;
for (i=0;i<N;i++){
    soma += v[i];
}
int media = soma /N ;
int maioresqmedia = 0 ;
for (i=0;i<N;i++){
    if (v[i] > media ){
        maioresqmedia += 1 ;
    }
}
return maioresqmedia ;
}
