#include <stdio.h>




int main(){

    char str[20] = "Geeks";

    // Pointer variable which stores
    // the starting address of
    // the character array str
    char* ptr = str;

    // While loop will run till 
    // the character value is not
    // equal to null character
    while (*ptr != '\0') {
        printf("%c", *ptr);
        printf("[%p]",ptr);
        
                // ele vai printar caracter por caracter da string 
        //exceto o '/0' pq a condicional do loop para no /0 
        //e como o printf, por padrão , não pula a linha , vai printar um caracter atrás do outro 
        ptr++;
    }
    return 0;
}
