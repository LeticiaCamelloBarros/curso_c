int buscar_melhor_aluno(struct Aluno v_struct[],int n){
  float maior_media = 0;
  int indice_m_media = 0;
 for (int i =0;i<n;i++){
     float media =(( v_struct[i].nota1 )+ (v_struct[i].nota2) + (v_struct[i].nota3 ))/3;
     if( media > maior_media) {
         maior_media = media ;
         indice_m_media = i ;
     } 
 }  return indice_m_media;
}
