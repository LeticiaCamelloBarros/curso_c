int ind_or_not (int N,int m[N][N]) 
{
int qntd_1total = 0 ; 
int qntd_0total = 0 ;
int i = 0 ;
int j = 0 ;
	for (i=0; i<N; i++)
	{
		for (j=0; j<N; j++)
		{
			if (i == j ) 
			{
				if (m[i][j] == 1) 
				{
                   qntd_1total += 1 ;
				}
			}
			else
			{
			if (m[i][j]==0){
			    qntd_0total += 1 ;
			}    
			}

		}
	}
	if (qntd_1total == N && qntd_0total == (N*N)-N ){
	    return 1;
	}
	else {
	    return 0;
	}
}
