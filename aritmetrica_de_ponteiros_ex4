// Online C compiler to run C program online
#include <stdio.h>
const int Max = 3;
int main() {


int arr[] = {1,45,78};
int i , *ptr;
ptr = &arr[Max-1];
//aqui ele colocou o endereço do ponteiro como o endereço 
// do último elemento do vetor , pois queremos percorrer esse vetor de 
//trás para frente 
for(i=Max;i>0;i--){
    printf("the adress of the pointer = %p  ",ptr);
    printf(" | ");
    printf("the value of the pointer = %d ",(void*)ptr);
    printf("\n");
    //o void evita warning do compilador 
    ptr--;
}


}
