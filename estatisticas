void estatisticas (float v_temps[],int tam,float*media,float*maior,float*menor){
    for(int i = 0;i<tam;i++){
        if( v_temps[i] >= *maior){
            *maior = v_temps[i];
            *media += v_temps[i];

        }else if ( v_temps[i] <= *menor){
            *menor = v_temps[i];
            *media += v_temps[i];

        }else {
*media += v_temps[i];
        }
    }
    *media = *media / tam ;
}
