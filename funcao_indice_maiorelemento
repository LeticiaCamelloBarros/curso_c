}
int maior_indic(int N,int vetor[N]){
    int i = 0 ;
   int  maior_indice = 0 ;
   int  maior_elemento = 0 ;
    for (i=0;i<N;i++){
        if (vetor[i] > maior_elemento){
            maior_elemento = vetor[i];
            maior_indice = i;
        }
    }
    return maior_indice;
}
