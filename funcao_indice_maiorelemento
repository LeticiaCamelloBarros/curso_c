#include <stdio.h>
int maior_indic(int N,int vetor[N]);
int main()
{
int N;
printf("qual o tamanho do nosso vetor? ");
scanf("%d",&N);
int vetor[N];
int ordem = 0 ;
int i = 0 ;
for (i=0;i<N;i++){
    ordem = ordem + 1 ; 
    printf("digite o %d elemento do nosso vetor",ordem);
    scanf("%d",&vetor[i]);

}
int indice_maior = 0 ;
indice_maior = maior_indic(N,vetor);
