#include <stdio.h>
int funcao (int v[],int N);
int i = 0 ;

int main()
{
  int N ;
  printf("digite a quantidade de inteiros tem esse vetor");
  scanf("%d",&N);
  int v[N];
  for (i=0;i<N;i++){
      int posicao = i+1 ; 
      printf("qual o número do  %d item do vetor ",posicao);
      scanf("%d",&v[i]);
      printf("\n");
  }
  printf("a quantidade de números pares no vetor é %d",funcao(v,N));
}
int quant_pares = 0;
int funcao (int v[],int N){
    if (N == 0 ) 
   { return  0 ;}
    else{
    for (i=0;i<N;i++){
        if (v[i] % 2 == 0) {
           quant_pares += 1 ;
        }
    }}
    return quant_pares;
}
