#include <stdio.h>
void separar_transacoes(float *valores,int n,float *positivos, int *qtd_pos,
float *negativos,int *qtd_neg);
int main()
{
int n ; 
printf("qual o tamanho do nosso vetor ? ");
scanf("%d",&n);
float valores[n],positivos[n],negativos[n];
for (int i =0;i<n;i++){
    float x ;
    int posic = i +1 ;
    printf("qual o %d valor do vetor",posic);
    scanf("%f",&x);
    valores[i] = x ;
//fim do loop
}
int qtd_pos = 0  , qtd_neg = 0;
 separar_transacoes(valores,n,positivos,&qtd_pos,negativos,&qtd_neg);
printf("{");
for (int i =0;i<n;i++){
    printf("%f ",valores[i]);
}
printf("}\n");
printf("{");
for (int i =0;i<qtd_pos;i++){
    printf("%f ",positivos[i]);
}
printf("}\n");
printf("{");
for(int i =0;i<qtd_neg;i++){
    printf("%f",negativos[i]);
}
printf("}\n");
printf("quantidade de positivos %d",qtd_pos);
printf("quantidade de negativos %d",qtd_neg);
//fim da main
}
void separar_transacoes(float valores[],int n,float *positivos, int *qtd_pos,float *negativos
,int *qtd_neg){
 for (int i =0;i<n;i++){
     if (valores[i]>0){
         positivos[(*qtd_pos)] = valores[i];
         (*qtd_pos) ++;
     }else if (valores[i]==0){
          continue;
     }else {
         negativos[(*qtd_neg)]=valores[i];
        (*qtd_neg) ++;
     }
 }   
}
