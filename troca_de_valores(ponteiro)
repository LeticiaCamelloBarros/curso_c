#include <stdio.h>

void trocar(int*pa,int*pb);
int main()
{
int a = 3; 
int b = 4;
trocar(&a,&b);
printf("%d",a);
printf("\n");
printf("%d",b);
}
void trocar(int*pa,int*pb){
    int temp ; 
    temp = *pa ; 
    *pa = *pb ;
    *pb = temp ;
}
